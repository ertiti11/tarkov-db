---
import '../styles/globals.css';

interface Props {
  title?: string;
  active?: string;
}
const { title = 'Tarkov Helper', active = '' } = Astro.props;

const navItems = [
  { href: '/',        i18nKey: 'nav.market',  key: 'market' },
  { href: '/guns/',   i18nKey: 'nav.guns',    key: 'guns' },
  { href: '/ammo/',   i18nKey: 'nav.ammo',    key: 'ammo' },
  { href: '/barter/', i18nKey: 'nav.barter',  key: 'barter' },
  { href: '/craft/',  i18nKey: 'nav.craft',   key: 'craft' },
  { href: '/traders/',i18nKey: 'nav.traders', key: 'traders' },
  { href: '/maps/',   i18nKey: 'nav.maps',    key: 'maps' },
  { href: '/quests/', i18nKey: 'nav.quests',  key: 'quests' },
  { href: '/hideout/',i18nKey: 'nav.hideout', key: 'hideout' },
];
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <link rel="preconnect" href="https://assets.tarkov.dev" crossorigin />
  <link rel="preconnect" href="https://eft-cdn.dvcstudiox.workers.dev" crossorigin />
  <link rel="preconnect" href="https://json.tarkov.dev" crossorigin />
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' fill='%230a0a0b'/%3E%3Ctext x='16' y='22' text-anchor='middle' font-family='monospace' font-size='18' font-weight='bold' fill='%23c9a44c'%3ET%3C/text%3E%3C/svg%3E" />
</head>
<body class="min-h-screen flex flex-col">

  <!-- Global i18n system -->
  <script is:inline>
    window.__lang = localStorage.getItem('tdb-lang') || (navigator.language.startsWith('es') ? 'es' : 'en');
    window.__translations = {
      'nav.market': { en: 'Market', es: 'Mercado' },
      'nav.guns': { en: 'Guns', es: 'Armas' },
      'nav.ammo': { en: 'Ammo', es: 'Munición' },
      'nav.barter': { en: 'Barter', es: 'Trueque' },
      'nav.craft': { en: 'Craft', es: 'Fabricación' },
      'nav.traders': { en: 'Traders', es: 'Comerciantes' },
      'nav.maps': { en: 'Maps', es: 'Mapas' },
      'nav.quests': { en: 'Quests', es: 'Misiones' },
      'nav.hideout': { en: 'Hideout', es: 'Refugio' },
      'market.filter': { en: 'Filter visible rows…', es: 'Filtrar filas visibles…' },
      'market.allCategories': { en: 'All categories', es: 'Todas las categorías' },
      'market.sort': { en: 'Sort:', es: 'Ordenar:' },
      'market.sortAvg': { en: 'Avg 24h ↓', es: 'Prom 24h ↓' },
      'market.sortLow24': { en: 'Low 24h ↓', es: 'Mín 24h ↓' },
      'market.sortHigh24': { en: 'High 24h ↓', es: 'Máx 24h ↓' },
      'market.sortLastLow': { en: 'Last Low ↓', es: 'Último mín ↓' },
      'market.sortChange': { en: 'Change 48h ↓', es: 'Cambio 48h ↓' },
      'market.sortProfit': { en: 'Trader profit ↓', es: 'Beneficio trader ↓' },
      'market.sortName': { en: 'Name A→Z', es: 'Nombre A→Z' },
      'market.loading': { en: 'Loading items…', es: 'Cargando objetos…' },
      'market.items': { en: 'items', es: 'objetos' },
      'market.livePrices': { en: 'live {mode} prices', es: 'precios {mode} en vivo' },
      'table.item': { en: 'Item', es: 'Objeto' },
      'table.avg24': { en: 'Avg 24h', es: 'Prom 24h' },
      'table.low24': { en: 'Low 24h', es: 'Mín 24h' },
      'table.high24': { en: 'High 24h', es: 'Máx 24h' },
      'table.lastLow': { en: 'Last Low', es: 'Último mín' },
      'table.change48': { en: 'Δ 48h', es: 'Δ 48h' },
      'table.bestTrader': { en: 'Best Trader', es: 'Mejor trader' },
      'search.placeholder': { en: 'Search items, traders, quests… (Ctrl+K)', es: 'Buscar objetos, traders, misiones… (Ctrl+K)' },
      'footer.data': { en: 'Data from tarkov.dev · Not affiliated with BSG · Built with Astro', es: 'Datos de tarkov.dev · No afiliado con BSG · Hecho con Astro' },
    };
    window.__t = function(key) {
      var t = window.__translations[key];
      return t ? (t[window.__lang] || t['en'] || key) : key;
    };
  </script>

  <header class="border-b border-bg-border bg-bg-elev sticky top-0 z-40 backdrop-blur">
    <div class="max-w-[1600px] mx-auto px-4 h-14 flex items-center gap-6">
      <a href="/" class="flex items-center gap-2 group">
        <span class="text-accent font-bold text-lg tracking-tight">⛬ Tarkov Helper</span>
      </a>
      <nav class="flex items-center gap-1 text-sm">
        {navItems.map((n) => (
          <a href={n.href}
             data-i18n={n.i18nKey}
             class={`px-3 py-1.5 rounded transition-colors ${active === n.key ? 'text-accent bg-bg-card' : 'text-text-dim hover:text-text hover:bg-bg-hover'}`}>
            {n.i18nKey.split('.')[1].charAt(0).toUpperCase() + n.i18nKey.split('.')[1].slice(1)}
          </a>
        ))}
      </nav>
      <div class="flex-1 max-w-md ml-auto relative">
        <input id="globalSearch" type="text" placeholder="Search items, traders, quests… (Ctrl+K)"
               data-i18n-placeholder="search.placeholder"
               class="w-full bg-bg-card border border-bg-border rounded px-3 py-1.5 text-sm placeholder:text-text-mute focus:outline-none focus:border-accent" />
        <div id="searchResults" class="absolute top-full mt-1 left-0 right-0 bg-bg-elev border border-bg-border rounded shadow-2xl max-h-96 overflow-auto hidden z-50"></div>
      </div>
      <div class="flex items-center gap-2 text-xs">
        <button id="langToggle" class="px-2 py-1 rounded bg-bg-card border border-bg-border text-text-dim hover:text-accent">EN</button>
        <button id="modeToggle" class="px-2 py-1 rounded bg-bg-card border border-bg-border text-text-dim hover:text-accent" data-mode="pve">PVE</button>
      </div>
    </div>
  </header>

  <main class="flex-1 max-w-[1600px] mx-auto w-full px-4 py-4">
    <slot />
  </main>

  <footer id="siteFooter" class="border-t border-bg-border py-4 text-center text-xs text-text-mute">
    Data from <a href="https://tarkov.dev" class="hover:text-accent">tarkov.dev</a> · Not affiliated with BSG · Built with Astro
  </footer>

  <script>
    // --- i18n: apply translations to data-i18n elements ---
    function applyI18n() {
      const t = (window as any).__t;
      if (!t) return;
      document.querySelectorAll<HTMLElement>('[data-i18n]').forEach((el) => {
        el.textContent = t(el.dataset.i18n);
      });
      document.querySelectorAll<HTMLInputElement>('[data-i18n-placeholder]').forEach((el) => {
        el.placeholder = t(el.dataset.i18nPlaceholder);
      });
      // Footer
      const footer = document.getElementById('siteFooter');
      if (footer) {
        const footerText = t('footer.data');
        footer.innerHTML = footerText.replace('tarkov.dev', '<a href="https://tarkov.dev" class="hover:text-accent">tarkov.dev</a>');
      }
    }

    // --- Language toggle (instant, no reload) ---
    const langBtn = document.getElementById('langToggle') as HTMLButtonElement;
    langBtn.textContent = ((window as any).__lang || 'en').toUpperCase();
    langBtn.addEventListener('click', () => {
      const cur = (window as any).__lang || 'en';
      const next = cur === 'en' ? 'es' : 'en';
      (window as any).__lang = next;
      localStorage.setItem('tdb-lang', next);
      langBtn.textContent = next.toUpperCase();
      applyI18n();
      // Notify page-level scripts (e.g. market) to re-apply their i18n
      window.dispatchEvent(new CustomEvent('lang-change', { detail: next }));
    });

    // Apply i18n on load
    applyI18n();

    // --- Global search with debounce ---
    let items: any[] = [];
    let fuseReady = false;
    const input = document.getElementById('globalSearch') as HTMLInputElement;
    const results = document.getElementById('searchResults') as HTMLDivElement;

    async function loadIndex() {
      if (fuseReady) return;
      try {
        const res = await fetch('/data/items.json');
        items = await res.json();
        fuseReady = true;
      } catch (e) { console.error(e); }
    }

    function score(q: string, it: any) {
      const n = it.n.toLowerCase();
      const sn = (it.sn || '').toLowerCase();
      if (n.startsWith(q)) return 0;
      if (sn.startsWith(q)) return 1;
      if (n.includes(q)) return 2;
      if (sn.includes(q)) return 3;
      return -1;
    }

    let timer: any;
    input?.addEventListener('input', () => {
      clearTimeout(timer);
      timer = setTimeout(async () => {
        const q = input.value.trim().toLowerCase();
        if (!q) { results.classList.add('hidden'); return; }
        await loadIndex();
        const hits: any[] = [];
        for (const it of items) {
          const s = score(q, it);
          if (s >= 0) hits.push({ ...it, _s: s });
          if (hits.length > 200) break;
        }
        hits.sort((a, b) => a._s - b._s);
        const top = hits.slice(0, 12);
        results.innerHTML = top.map((it) => `
          <a href="/item/${it.nn}/" class="flex items-center gap-3 px-3 py-2 hover:bg-bg-hover border-b border-bg-border last:border-0">
            <img src="${it.ic}" alt="" loading="lazy" class="w-8 h-8 object-contain" />
            <div class="flex-1 min-w-0">
              <div class="text-sm truncate">${it.n}</div>
              <div class="text-xs text-text-mute">${it.sn || ''}</div>
            </div>
            <div class="text-num text-sm text-accent">${(it.a24 || it.llp || it.bp || 0).toLocaleString()} ₽</div>
          </a>
        `).join('');
        results.classList.toggle('hidden', top.length === 0);
      }, 80);
    });

    document.addEventListener('click', (e) => {
      if (!results.contains(e.target as Node) && e.target !== input) {
        results.classList.add('hidden');
      }
    });

    document.addEventListener('keydown', (e) => {
      if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
        e.preventDefault();
        input.focus();
        input.select();
      }
      if (e.key === 'Escape') {
        results.classList.add('hidden');
        input.blur();
      }
    });

    // --- Game mode toggle (debounced to prevent rapid switching issues) ---
    const modeBtn = document.getElementById('modeToggle') as HTMLButtonElement;
    const savedMode = localStorage.getItem('tdb-mode') || 'pve';
    modeBtn.textContent = savedMode.toUpperCase();
    modeBtn.dataset.mode = savedMode;
    let modeDebounce: any;
    modeBtn.addEventListener('click', () => {
      const next = modeBtn.dataset.mode === 'pve' ? 'pvp' : 'pve';
      modeBtn.dataset.mode = next;
      modeBtn.textContent = next.toUpperCase();
      localStorage.setItem('tdb-mode', next);
      // Debounce: wait 300ms before dispatching to avoid stacking fetches
      clearTimeout(modeDebounce);
      modeDebounce = setTimeout(() => {
        window.dispatchEvent(new CustomEvent('mode-change', { detail: next }));
      }, 300);
    });
  </script>
</body>
</html>
