---
import Base from '../layouts/Base.astro';
import hideout from '../data/hideout.json';
---
<Base title="Hideout — Tarkov Helper" active="hideout">
  <h1 class="text-lg font-semibold mb-4">Hideout Stations</h1>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    {(hideout as any[]).map((s) => (
      <div class="bg-bg-elev border border-bg-border rounded p-4">
        <h2 class="text-base font-semibold mb-3">{s.name}</h2>
        <div class="space-y-3">
          {(s.levels || []).map((lv: any) => (
            <div class="border-t border-bg-border pt-2">
              <div class="text-xs text-text-mute mb-1">Level {lv.level} · {Math.round((lv.constructionTime||0)/60)}min</div>
              {(lv.itemRequirements || []).length === 0 ? (
                <div class="text-xs text-text-mute">No item requirements</div>
              ) : (
                <div class="flex flex-wrap gap-1">
                  {lv.itemRequirements.map((r: any) => (
                    <a href={`/item/${r.item.id}/`} class="flex items-center gap-1 px-2 py-1 bg-bg-card rounded text-xs">
                      <img src={r.item.iconLink} class="w-5 h-5 object-contain" loading="lazy" />
                      <span class="truncate max-w-[140px]">{r.item.shortName}</span>
                      <span class="text-text-mute">×{r.count}</span>
                    </a>
                  ))}
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</Base>
